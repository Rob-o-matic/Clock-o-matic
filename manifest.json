{
  "manifest_version": 3,
  "name": "Time-o-matic",
  "version": "1.3",
  "description": "Visual Timer & Schedule for Google Slides",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_title": "Toggle Clock",
    "default_icon": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-clock-command": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "MacCtrl+Shift+C"
      },
      "description": "Toggle the Clock"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/presentation/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}